<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_vendor_bills']" position="after">
                <block
                    id="invoice_import"
                    invisible="not has_accounting_entries"
                    title="Vendor Bills Import"
                >
                    <setting
                        id="adjustment_debit_account_id"
                        help="Expense account used for adjustment invoice line"
                    >
                        <field
                            name="adjustment_debit_account_id"
                            options="{'no_create': True}"
                        />
                    </setting>
                    <setting
                        id="adjustment_credit_account_id"
                        help="Income account used for adjustment invoice line"
                    >
                        <field
                            name="adjustment_credit_account_id"
                            options="{'no_create': True}"
                        />
                    </setting>
                    <setting
                        id="invoice_import_email"
                        help="This field is used in multi-company setups to import the invoices received by the mail gateway in the appropriate company."
                    >
                        <field name="invoice_import_email" />
                    </setting>
                    <setting
                        id="invoice_import_create_bank_account"
                        help="If enabled, Odoo will auto-create the bank account of suppliers upon vendor bill import."
                    >
                        <field name="invoice_import_create_bank_account" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
